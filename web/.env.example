# Postgres
DATABASE_URL=postgres://mailkit:mailkit@localhost:5432/mailkit

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Better-Auth
BETTER_AUTH_SECRET=replace_me_with_openssl_rand_hex_32
BETTER_AUTH_URL=http://localhost:3000

# SMTP (Postal self-hosted)
SMTP_HOST=postal.yourdomain.com
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MailKit <hello@yourdomain.com>"

# App
APP_URL=http://localhost:3000
TRACKING_DOMAIN=track.yourdomain.com
